# Copia este archivo como .env. Los valores son ejemplos, no secretos reales.
AI_PLATFORM_NETWORK=ai-platform
HTTP_PORT=8080

POSTGRES_DB=ai_data_chat
POSTGRES_USER=ai_data_chat
POSTGRES_PASSWORD=replace-with-a-long-random-password

MCP_BASE_URL=http://data-platform-mcp:8000
MCP_ENDPOINT=/mcp
MCP_PROTOCOL_VERSION=2025-11-25
MCP_CONTRACT_MAJOR=1

# Sprint 2 usara una clave aleatoria de 32 bytes codificada en base64.
CREDENTIAL_MASTER_KEY=replace-with-base64-encoded-32-byte-key
ALLOW_PUBLIC_REGISTRATION=true
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_TIMEOUT=30m
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=1m
REGISTRATION_RATE_LIMIT_ATTEMPTS=10
REGISTRATION_RATE_LIMIT_WINDOW=1h

MAX_UPLOAD_BYTES=26214400
MAX_TOOL_ROUNDS=6
MAX_TOOL_RESULT_BYTES=1048576
NGINX_MAX_UPLOAD_SIZE=25m
