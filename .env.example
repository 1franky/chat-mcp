# Copia este archivo como .env. Los valores son ejemplos, no secretos reales.
AI_PLATFORM_NETWORK=ai-platform
HTTP_PORT=3000

POSTGRES_DB=ai_data_chat
POSTGRES_USER=ai_data_chat
POSTGRES_PASSWORD=replace-with-a-long-random-password

MCP_INTEGRATION_MODE=fake
MCP_BASE_URL=http://data-platform-mcp:8000
MCP_ENDPOINT=/mcp
MCP_PROTOCOL_VERSION=2025-11-25
MCP_CONTRACT_MAJOR=1
MCP_STATUS_REFRESH_INTERVAL=30s
MCP_TOOL_CALL_TIMEOUT=20s
MCP_HTTP_TIMEOUT=10s
MCP_HTTP_MAX_RESPONSE_BYTES=1048576

# Genera una clave local con: openssl rand -base64 32
CREDENTIAL_MASTER_KEY=replace-with-base64-encoded-32-byte-key
CREDENTIAL_KEY_VERSION=1
# Hosts exactos autorizados para OpenAI-compatible y Ollama. Vacio bloquea todos.
PROVIDER_ALLOWED_HOSTS=
# Subconjunto de hosts anteriores que pueden usar HTTP por ser internos.
PROVIDER_ALLOWED_HTTP_HOSTS=
PROVIDER_HTTP_TIMEOUT=10s
PROVIDER_MAX_RESPONSE_BYTES=1048576
CHAT_STREAM_TIMEOUT=2m
CHAT_HEARTBEAT_INTERVAL=15s
CHAT_MAX_HISTORY_MESSAGES=200
CHAT_MAX_HISTORY_CHARACTERS=200000
CHAT_MAX_RESPONSE_CHARACTERS=1000000
ALLOW_PUBLIC_REGISTRATION=true
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_TIMEOUT=30m
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=1m
REGISTRATION_RATE_LIMIT_ATTEMPTS=10
REGISTRATION_RATE_LIMIT_WINDOW=1h

MAX_UPLOAD_BYTES=26214400
MAX_TOOL_ROUNDS=6
MAX_TOOL_RESULT_BYTES=1048576
NGINX_MAX_UPLOAD_SIZE=25m
